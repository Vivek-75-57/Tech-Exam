# ============================================
# ExamForge Backend Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3001

# ============================================
# Groq API Configuration (REQUIRED)
# ============================================
# Get your API key from: https://console.groq.com/keys
# Free tier includes rate limits suitable for development and testing
GROQ_API_KEY=your_api_key_here

# Optional: Specify which Groq model to use
# Available models:
#   - llama-3.1-8b-instant (default, fast and cost-effective)
#   - llama-3.1-70b-versatile (more powerful but slower)
#   - mixtral-8x7b-32768 (alternative model)
# GROQ_MODEL=llama-3.1-8b-instant

# Optional: Max tokens for Groq API responses
# GROQ_MAX_TOKENS=4096

# ============================================
# Demo Mode
# ============================================
# Set to true to use mock questions instead of live API
# Useful for development without API cost
# If GROQ_API_KEY is not set, demo mode is automatically enabled
# DEMO_MODE=false

# ============================================
# ChromaDB Configuration
# ============================================
# URL for ChromaDB vector store (for question caching)
CHROMADB_URL=http://localhost:8001

# ============================================
# CORS Configuration
# ============================================
# Frontend origin for CORS headers
CORS_ORIGIN=http://localhost:5173

# ============================================
# NOTES
# ============================================
# 1. GROQ_API_KEY is the only required field
# 2. If not provided, the app will run in DEMO_MODE automatically
# 3. Get free Groq API key at: https://console.groq.com
# 4. For production, use environment variables management (e.g., GitHub Secrets)
# 5. Never commit .env file to version control

